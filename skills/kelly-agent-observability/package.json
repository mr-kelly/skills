{
  "name": "kelly-agent-observability",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Agent Fleet Observability Desk App-in-Skill — local mock dashboard for a fleet of LLM agents behind a shared AI gateway (Hono server, zero-build vanilla frontend).",
  "engines": {
    "node": ">=23.6"
  },
