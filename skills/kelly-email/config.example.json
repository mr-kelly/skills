  "official_urls": {
    "homepage": "https://example.com",
    "docs": "https://docs.example.com",
    "support": "mailto:support@example.com",
    "pricing": "https://example.com/pricing",
    "calendar": "https://cal.example.com/your-name",
    "youtube": "https://www.youtube.com/@example",
    "primary_cta": "https://example.com"
  },
  "knowledge_base": {
    "enabled": true,
    "usage": "Use these sources for product facts, positioning, support answers, and reply drafts. If the answer is not covered, ask the user instead of inventing.",
    "sources": [
      {
        "source_id": "website",
        "type": "url",
        "title": "Public website",
        "url": "https://example.com",
        "use_for": [
          "product positioning",
          "CTA links"
        ]
      },
      {
        "source_id": "docs",
        "type": "url",
        "title": "Product docs",
        "url": "https://docs.example.com",
        "use_for": [
          "how-to answers",
          "feature details"
        ]
      },
      {
        "source_id": "local-faq",
        "type": "file",
        "title": "Local FAQ notes",
        "path": "~/Documents/kelly-email/faq.md",
        "use_for": [
          "repeat support answers"
        ]
      }
    ],
    "facts": [
      "Add durable product facts here. Keep them short and non-secret."
    ],
    "do_not_say": [
      "Do not promise custom work, refunds, discounts, roadmap dates, or legal/compliance guarantees unless the user explicitly approves."
    ]
  },
  "routing_rules": [
    {
      "rule_id": "reply-to-original-recipient",
      "priority": 100,
      "when": "incoming message recipient exactly matches a configured identity",
      "action": "reply using that identity"
    },
    {
      "rule_id": "continue-thread-identity",
      "priority": 90,
      "when": "thread already has prior outbound replies from a configured identity",
      "action": "continue using the same identity unless the user says otherwise"
    },
    {
      "rule_id": "ask-when-ambiguous",
      "priority": 10,
      "when": "more than one identity matches or no identity is configured",
      "action": "draft the reply, but ask the user which reply_as identity to use before sending"
    }
  ],
  "approval_policy": {
    "require_batch_approval_before_reading": true,
    "require_action_approval_before_sending": true,
    "require_action_approval_before_mailbox_changes": true,
    "default_batch": {
      "review_quota": 5,
      "max_auto_cleanup_threads": null,
      "actions": "triage_and_draft_unread_only",
      "stop_condition": "stop_when_needs_review_reaches_quota_or_inbox_done",
      "cache_dir": ".agents/skills/kelly-email/.cache"
    },
    "allowed_preapproval_actions": [
      "explain workflow",
      "prepare configuration",
      "propose batch plan",
      "ask clarifying questions"
    ]
  },
  "style": {
    "default_language": "auto",
    "preset": "concise_support",
    "tone": "concise, warm, direct",
    "audience": "customers, prospects, partners, and operational notifications",
    "max_reply_words": 180,
    "paragraph_style": "short paragraphs, direct answer first",
    "include_short_quote": true,
    "signature_mode": "identity_signature",
    "preferred_signoff": "Best,",
    "reply_rules": [
      "Lead with the useful answer.",
      "Use customer language when clear.",
      "Ask one concrete next question when more context is needed.",
      "Avoid over-promising on pricing, compliance, roadmap, refunds, or custom work."
    ],
    "cta_urls": {
      "default": "https://example.com"
    }
  },
  "risk_policy": {
    "block_by_default": [
      "send_reply"
    ],
    "review_keywords": {
      "money": [
        "invoice",
        "receipt",
        "payment",
        "billing",
        "refund",
        "charge",
        "subscription",
        "账单",
        "发票",
        "付款",
        "支付"
      ],
      "security": [
        "password",
        "login",
        "account access",
        "privacy",
        "PAT",
        "token"
      ],
      "attachments": [
        "report attached",
        "invoice attached"
      ]
    },
    "allow_override_for": [
      "archive",
      "mark_read"
    ]
  }
}
