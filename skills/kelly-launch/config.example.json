{
  "data_provider": "local",
  "busabase": {
    "base_url": "http://127.0.0.1:3000",
    "base_id": "REPLACE_WITH_BUSABASE_BASE_ID",
    "api_key_env": "KELLY_LAUNCH_BUSABASE_API_KEY",
    "_note": "Launch-item fields (phase, title, channel_id, readiness, proposed_action, status, draft, format, reason, ref, risk) map to a Busabase record commit's fields. Agent-prepared items become change requests; approve->review, edits->operation revisions, ship (submit/pitch/publish)->merge. Env overrides: KELLY_LAUNCH_BUSABASE_URL / KELLY_LAUNCH_BUSABASE_BASE_ID / KELLY_LAUNCH_BUSABASE_API_KEY. The open-source single-tenant apps/busabase needs no api key; only busabase-cloud does."
  },
  "locale": "auto",
  "product": {
    "name": "Example Product",
    "tagline": "One-line positioning statement",
    "homepage": "https://example.com",
    "category": "Developer tools"
  },
  "launch": {
    "target_date": "2026-01-15",
    "timezone": "UTC",
    "phases": ["research", "assemble", "mobilize", "prove"]
  },
  "channels": [
    {
      "channel_id": "product_hunt",
      "type": "product_hunt",
      "display_name": "Product Hunt",
      "handoff_skill": "product-launch-video",
      "token_env": "KELLY_LAUNCH_PH_TOKEN"
    },
    {
      "channel_id": "hacker_news",
      "type": "hacker_news",
      "display_name": "Hacker News (Show HN)",
      "handoff_skill": "",
      "token_env": ""
    },
    {
      "channel_id": "press",
      "type": "press",
      "display_name": "Press outreach",
      "handoff_skill": "kelly-email",
      "token_env": "KELLY_LAUNCH_EMAIL_TOKEN"
    },
    {
      "channel_id": "email",
      "type": "email",
      "display_name": "Launch email",
      "handoff_skill": "kelly-email",
      "token_env": "KELLY_LAUNCH_EMAIL_TOKEN"
    }
  ],
  "press_lists": [
    {
      "list_id": "press_tier1",
      "display_name": "Tier 1 press contacts"
    }
  ],
  "readiness_policy": {
    "block_on": ["press", "product_hunt", "hacker_news"],
    "min_ship_ratio": 0.8
  },
  "risk_policy": {
    "review_keywords": {
      "public": ["launch", "press", "embargo"],
      "commitment": ["pricing", "guarantee", "sla"]
    }
  },
  "style": {
    "tone": "clear, confident, concrete",
    "signature": "Example Operator",
    "language": "auto"
  }
}
